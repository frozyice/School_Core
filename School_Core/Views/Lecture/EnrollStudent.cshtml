@model School_Core.ViewModels.Lecture.EnrollStudentViewModel

<div class="container">
    <div class="col-md-6">
        <form asp-controller="Lecture" asp-action="EnrollStudent" method="post">
            <input asp-for="Id" />
            <div class="form-group">
                
                
                <table class="table">
                    <thead>
                    <tr>
                        <th>Student</th>
                        <th>Enrolled</th>
                    </tr>
                    </thead>
                    <tbody>
                        
                    @{ var i = 0; }
                    @foreach (var student in Model.StudentsEnrolled)
                    {
                        <tr>
                            <td>@student.Name</td>
                            <td>@student.isEnrolled</td>
                            <td><input asp-for="@Model.StudentsEnrolled.ToList()[i].isEnrolled"/></td>
                        </tr>
                        i++;
                    }
                    </tbody>
                </table>

                <label asp-for="StudentName"></label>
                <input asp-for="StudentName" class="form-control"/>
                <span asp-validation-for="StudentName" class="text-danger"></span>

            </div>
            <div class="form-group">
                <button type="submit" class="btn btn-primary form-control">Enroll Students</button>
            </div>
        </form>
    </div>
</div>