@model School_Core.ViewModels.Teacher.TeacherViewModel

@{
    ViewData["Title"] = "View";
}
<h1 style="color:@Model.HeadingColor">@Model.HeadingTitle</h1>

<div class="container">
    <div class="row">
        <div class="col">

            <table class="table">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Lecture</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var teacher in Model.TeacherListViewModels)
                    {
                        <tr>
                            <td>
                                @*@Html.ActionLink(teacher.Name, "Details", "Teacher", new { id = teacher.Id })*@
                                @teacher.Name
                            </td>
                            <td>
                                teacher.lecture
                            </td>
                            <td>
                                <a class="btn btn-outline-primary" asp-controller="Lecture" asp-action="Assign to Lecture">Assign to Lecture</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

        </div>
    </div>
    <div style="margin-top:20px">

        @await Component.InvokeAsync("Counter", new { color = Model.HeadingColor})
    </div>
</div>